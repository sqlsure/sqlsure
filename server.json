{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.sqlsure/sqlsure",
  "description": "Semantic SQL inspector: catches double-counting, wrong joins, PII exposure before execution.",
  "version": "0.1.1",
  "repository": {
    "url": "https://github.com/sqlsure/sqlsure",
    "source": "github"
  },
  "websiteUrl": "https://sqlsure.ai",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "sqlsure",
      "version": "0.1.1",
      "runtimeHint": "python",
      "transport": {
        "type": "stdio"
      },
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-m",
          "description": "run as module"
        },
        {
          "type": "positional",
          "value": "sqlsure.mcp_server",
          "description": "the MCP server module"
        }
      ],
      "packageArguments": [
        {
          "type": "named",
          "name": "--model",
          "description": "Path to semantic model JSON (or use --manifest with a dbt manifest.json)",
          "isRequired": true,
          "format": "filepath"
        }
      ]
    }
  ]
}
