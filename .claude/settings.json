{
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python -c ' *)",
      "Bash(curl -s -H 'Authorization: Bearer __CMDSUB_OUTPUT__' https://api.cloudflare.com/client/v4/zones?per_page=20)",
      "Bash(curl -s -H 'Authorization: Bearer __CMDSUB_OUTPUT__' https://api.cloudflare.com/client/v4/zones?per_page=1)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:github.com)",
      "Bash(git rm *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(GIT_SSL_CAINFO=/etc/ssl/cert.pem git push -f origin main)",
      "Bash(curl -sv --max-time 10 https://github.com -o /dev/null)",
      "Bash(curl -s https://pypi.org/pypi/sqlsure/json)",
      "Bash(GIT_SSL_CAINFO=/etc/ssl/cert.pem git push -q)",
      "Bash(brew install *)",
      "Bash(mcp-publisher --version)",
      "Bash(mcp-publisher login *)",
      "Bash(curl -s -o /dev/null -w \"sqlsure.github.io → HTTP %{http_code}\\\\n\" --max-time 15 https://sqlsure.github.io/)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.pypirc)",
      "Read(**/*.pypirc)"
    ]
  }
}
